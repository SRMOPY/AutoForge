# OPTION 1: Gemini (free) — https://aistudio.google.com/apikey
MODEL_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# OPTION 2: Groq (free, faster) — https://console.groq.com
# MODEL_PROVIDER=groq
# GROQ_API_KEY=your_groq_api_key_here

# OPTION 3: OpenAI (paid) — https://platform.openai.com/api-keys
# MODEL_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
